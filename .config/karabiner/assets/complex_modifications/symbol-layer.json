          "to": [{ "set_variable": { "name": "symbol_layer", "value": 1 } }],
          "to_after_key_up": [
            { "set_variable": { "name": "symbol_layer", "value": 0 } }
          ],
          "to_if_alone": [{ "key_code": "spacebar" }],
          "conditions": [
            {
              "identifiers": [{ "product_id": 12292, "vendor_id": 14000 }],
              "type": "device_unless"
            },
            {
              "identifiers": [{ "product_id": 12484, "vendor_id": 14000 }],
              "type": "device_unless"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            { "name": "symbol_layer", "type": "variable_if", "value": 1 }
          ],
          "from": { "key_code": "q" },
          "to": [
            { "key_code": "grave_accent_and_tilde", "modifiers": ["shift"] }
          ]
        },

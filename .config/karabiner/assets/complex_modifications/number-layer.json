{
  "rules": [
    {
      "description": "Number Layer",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "right_shift",
            "modifiers": { "optional": ["any"] }
          },
          "to": [
            { "set_variable": { "name": "number_layer", "value": 1 } }
          ],
          "to_after_key_up": [
            { "set_variable": { "name": "number_layer", "value": 0 } }
          ],
          "conditions": [
            {
              "identifiers": [{ "product_id": 12292, "vendor_id": 14000 }],
              "type": "device_unless"
            },
            {
              "identifiers": [{ "product_id": 12484, "vendor_id": 14000 }],
              "type": "device_unless"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            { "name": "number_layer", "type": "variable_if", "value": 1 }
          ],
          "from": { "key_code": "comma" },
          "to": [
            { "key_code": "1" }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            { "name": "number_layer", "type": "variable_if", "value": 1 }
          ],
          "from": { "key_code": "period" },
          "to": [
            { "key_code": "2" }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            { "name": "number_layer", "type": "variable_if", "value": 1 }
          ],
          "from": { "key_code": "slash" },
          "to": [
            { "key_code": "3" }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            { "name": "number_layer", "type": "variable_if", "value": 1 }
          ],
          "from": { "key_code": "k" },
          "to": [
            { "key_code": "4" }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            { "name": "number_layer", "type": "variable_if", "value": 1 }
          ],
          "from": { "key_code": "l" },
          "to": [
            { "key_code": "5" }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            { "name": "number_layer", "type": "variable_if", "value": 1 }
          ],
          "from": { "key_code": "semicolon" },
          "to": [
            { "key_code": "6" }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            { "name": "number_layer", "type": "variable_if", "value": 1 }
          ],
          "from": { "key_code": "i" },
          "to": [
            { "key_code": "7" }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            { "name": "number_layer", "type": "variable_if", "value": 1 }
          ],
          "from": { "key_code": "o" },
          "to": [
            { "key_code": "8" }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            { "name": "number_layer", "type": "variable_if", "value": 1 }
          ],
          "from": { "key_code": "p" },
          "to": [
            { "key_code": "9" }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            { "name": "number_layer", "type": "variable_if", "value": 1 }
          ],
          "from": { "key_code": "m" },
          "to": [
            { "key_code": "0" }
          ]
        }
      ]
    }
  ]
}

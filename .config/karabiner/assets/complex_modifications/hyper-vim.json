{
  "title": "Hyper Simple Vim Layer",
  "rules": [
    {
      "description": "Hyper + hjkl = arrows",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "h",
            "modifiers": { "mandatory": ["command", "control", "option"] }
          },
          "to": [{ "key_code": "left_arrow" }]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "j",
            "modifiers": { "mandatory": ["command", "control", "option"] }
          },
          "to": [{ "key_code": "down_arrow" }]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "k",
            "modifiers": { "mandatory": ["command", "control", "option"] }
          },
          "to": [{ "key_code": "up_arrow" }]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "l",
            "modifiers": { "mandatory": ["command", "control", "option"] }
          },
          "to": [{ "key_code": "right_arrow" }]
        }
      ]
    }
  ]
}
